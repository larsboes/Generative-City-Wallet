# ── Spark Backend Environment (template) ───────────────────────────────────────
# Copy to .env and fill in your values.

GOOGLE_AI_API_KEY=
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
LUMA_API_KEY=
LUMA_BASE_URL=https://api.lu.ma
LUMA_SEED_EVENTS_PATH=resources/mock_events_munich.json
CONTEXT_PROVIDER_TIMEOUT_SECONDS=4.0
PLACES_CACHE_TTL_SECONDS=300
LUMA_CACHE_TTL_SECONDS=300
GEMINI_MODEL=gemini-3.1-flash-lite-preview
SPARK_DB_PATH=data/spark.db
SPARK_HMAC_SECRET=spark-hackathon-secret-change-me
# Set to restrict CORS in production (comma-separated origins). Empty = allow all.
SPARK_CORS_ORIGINS=
# Set to require X-Admin-Secret header on destructive admin endpoints. Empty = no guard.
SPARK_ADMIN_SECRET=

# Mobile Strava OAuth (used by Expo app)
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=
EXPO_PUBLIC_STRAVA_REDIRECT_URI=spark://oauth/strava
